{
  "id": "openclaw-quality-hooks",
  "name": "OpenClaw Quality Hooks",
  "version": "2.0.0",
  "description": "ECC-style safety, formatting, reminder, and quality-gate hooks (with hookify-engine integration)",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "enabled": {
        "type": "boolean",
        "default": true
      },
      "configFile": {
        "type": "string"
      },
      "logDir": {
        "type": "string",
        "default": "~/.openclaw/logs/openclaw-quality-hooks"
      },
      "audit": {
        "type": "object",
        "properties": {
          "enabled": {
            "type": "boolean",
            "default": true
          },
          "logDir": {
            "type": "string"
          },
          "fileName": {
            "type": "string",
            "default": "audit.log.jsonl"
          },
          "maxBytes": {
            "type": "integer",
            "default": 1048576
          },
          "maxFiles": {
            "type": "integer",
            "default": 5
          }
        }
      }
    }
  }
}
