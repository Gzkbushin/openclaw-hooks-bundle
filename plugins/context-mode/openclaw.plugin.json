{
  "id": "context-mode",
  "name": "Context Mode",
  "description": "Privacy-first context optimization for OpenClaw",
  "version": "1.0.0",
  "configSchema": {
    "type": "object",
    "properties": {
      "enabled": { "type": "boolean", "default": true },
      "configFile": { "type": "string" },
      "dbPath": { "type": "string", "default": "~/.context-mode/db" },
      "maxContextSnapshots": { "type": "integer", "default": 50 },
      "maxMemorySnapshots": { "type": "integer", "default": 100 },
      "snapshotRetentionDays": { "type": "integer", "default": 7 }
    }
  }
}
